{
    "name": "artisan-build/sink-client",
    "description": "The capture transport side of Sink. Installed in Laravel apps whose outbound mail should be captured by a Sink server.",
    "keywords": ["sink", "mail", "laravel", "testing"],
    "license": "MIT",
    "type": "library",
    "version": "1.0.0",
    "repositories": [
        {
            "type": "path",
            "url": "../sink-contracts",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "artisan-build/sink-contracts": "^1.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "laravel/prompts": "^0.1 || ^0.2 || ^0.3",
        "symfony/mailer": "^7.0 || ^8.0",
        "symfony/mime": "^7.0 || ^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "ArtisanBuild\\SinkClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArtisanBuild\\SinkClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "lint:test": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "ArtisanBuild\\SinkClient\\SinkClientServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
